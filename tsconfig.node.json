{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node", "electron"]
  },
  "include": ["vite.config.ts", "electron"]
}
